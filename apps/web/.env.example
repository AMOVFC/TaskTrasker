# Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://olngcuxyzzfwspgjsoyd.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_5xA-hPikSf7WyY216269Vg_E-zfhfi3

# Legacy fallback (optional if publishable key is set)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_5xA-hPikSf7WyY216269Vg_E-zfhfi3

# Server-side app origin used for OAuth callback redirects (preferred)
APP_URL=http://localhost:3000

# Backward-compatible fallback (prefer APP_URL for server code)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Resend email service (https://resend.com)
RESEND_API_KEY=re_REPLACE_ME
# "From" address — must be a verified domain in Resend (e.g. "TaskTrasker <noreply@yourdomain.com>")
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Supabase service role key — bypasses RLS; never expose client-side
# Found at: Supabase dashboard → Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME

# Secret header value required by POST /api/launch-notify/blast
# Generate with: openssl rand -hex 32
ADMIN_SECRET=REPLACE_ME

# Monitoring & analytics (optional placeholders)
# Google Analytics 4 measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-REPLACE_ME

# Microsoft Clarity project ID
NEXT_PUBLIC_CLARITY_PROJECT_ID=REPLACE_ME

